# Secrets — never commit these to a repo readable from Gitea.
*.key
*.keyfile
*.pem
id_rsa*
id_ed25519*
*.kdbx
secrets.yml
*vault*

# Ansible runtime noise
*.retry

# Machine-local values (prompted + saved by site.yml pre_tasks) — never commit.
host_vars/*/local.yml

# Local CI/lint artifacts (throwaway venv, ansible-lint cache, installed collections)
.venv/
.ansible/
